# OpenClaw UI environment example
# Copy this file to .env (or export as env vars before start)

# Bind address
HOST=0.0.0.0

# Service port
PORT=18790

# Optional auth token (strongly recommended in non-local environments)
UI_TOKEN=replace-with-a-strong-random-token

# Optional TLS (only if you want built-in HTTPS in server.js)
# SSL_KEY_PATH=
# SSL_CERT_PATH=
